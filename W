import asyncio
import pandas as pd
import requests
import json
import os
from playwright.async_api import async_playwright

# --- НАСТРОЙКИ ---
API_KEY = 'ВСТАВЬ_СЮДА_КЛЮЧ_ИЗ_DIFY' 
API_URL = 'http://localhost/v1/workflows/run'
EXCEL_FILE = 'leads.xlsx'

# Путь к профилю твоего Chrome (замени "Митяй" на свое имя пользователя в Windows, если нужно)
CHROME_USER_DATA = os.path.join(os.environ['LOCALAPPDATA'], r"Google\Chrome\User Data")

async def run_agent():
    if not os.path.exists(EXCEL_FILE):
        print(f"Ошибка: Файл {EXCEL_FILE} не найден!")
        return

    async with async_playwright() as p:
        print("Запуск реального Chrome для обхода блокировок...")
        
        # Запускаем браузер с твоим профилем
        context = await p.chromium.launch_persistent_context(
            user_data_dir=CHROME_USER_DATA,
            channel="chrome", # Используем именно установленный Chrome
            headless=False,
            args=[
                "--start-maximized",
                "--disable-blink-features=AutomationControlled"
            ],
            viewport=None
        )
        
        page = context.pages[0] if context.pages else await context.new_page()
        
        # Маскировка под человека
        await page.add_init_script("Object.defineProperty(navigator, 'webdriver', {get: () => undefined})")

        print("\n--- ЭТАП ПРОВЕРКИ АВТОРИЗАЦИИ ---")
        await page.goto("https://www.avito.ru/", wait_until="networkidle")
        print("Если ты не вошел в аккаунт — сделай это сейчас. Жду 45 секунд...")
        await asyncio.sleep(45)

        # Читаем таблицу
        try:
            df = pd.read_excel(EXCEL_FILE)
            for col in ['Имя', 'Ответ_ИИ', 'Статус', 'Просмотры', 'Ниша']:
                if col not in df.columns:
                    df[col] = ""
            df = df.astype(object)
        except Exception as e:
            print(f"Ошибка чтения Excel: {e}")
            await context.close()
            return

        changed = False

        for index, row in df.iterrows():
            # Ищем статус "Запустить" (без учета регистра)
            if str(row['Статус']).strip().lower() == 'запустить':
                url = str(row['Ссылка']).strip()
                print(f"\n[*] Перехожу по ссылке: {url}")

                try:
                    await page.goto(url, wait_until="domcontentloaded")
                    await asyncio.sleep(4)

                    # Сбор данных (Парсинг)
                    name_elem = page.locator('[data-marker="seller-info/name"]').first
                    name = await name_elem.inner_text() if await name_elem.count() > 0 else "Партнер"
                    
                    breadcrumb = page.locator('[data-marker="breadcrumbs/link"]')
                    niche = await breadcrumb.nth(2).inner_text() if await breadcrumb.count() > 2 else "Общая"
                    
                    views_elem = page.locator('[data-marker="item-view/total-views"]')
                    views = await views_elem.inner_text() if await views_elem.count() > 0 else "много"

                    print(f"    Собрано: {name.strip()} | {niche.strip()} | {views.strip()}")

                    # Запрос к Dify (твоя нейросеть)
                    payload = {
                        "inputs": {
                            "client_name": name.strip(),
                            "niche": niche.strip(),
                            "details": f"{views.strip()} просмотров"
                        },
                        "user": "avito_boss"
                    }
                    headers = {
                        "Authorization": f"Bearer {API_KEY}",
                        "Content-Type": "application/json; charset=utf-8"
                    }
                    
                    response = requests.post(
                        API_URL, 
                        data=json.dumps(payload, ensure_ascii=False).encode('utf-8'), 
                        headers=headers
                    )
                    
                    if response.status_code == 200:
                        ai_message = response.json().get('data', {}).get('outputs', {}).get('answer')
                        
                        # Отправка в чат Авито
                        chat_button = page.locator('[data-marker="item-view/messenger-button"]')
                        if await chat_button.is_visible():
                            await chat_button.click()
                            await asyncio.sleep(5)
                            
                            input_selector = '[data-marker="chat-input/input"]'
                            await page.wait_for_selector(input_selector)
                            await page.fill(input_selector, ai_message)
                            await asyncio.sleep(1)
                            await page.keyboard.press("Enter")
                            
                            print(f"    [УСПЕХ] Оффер отправлен!")
                            df.at[index, 'Статус'] = 'Отправлено'
                            df.at[index, 'Ответ_ИИ'] = ai_message
                            df.at[index, 'Имя'] = name.strip()
                            df.at[index, 'Ниша'] = niche.strip()
                            df.at[index, 'Просмотры'] = views.strip()
                            changed = True
                        else:
                            print("    [!] Кнопка чата не активна.")
                            df.at[index, 'Статус'] = 'Чат закрыт'
                    else:
                        print(f"    [Ошибка Dify] Код: {response.status_code}")

                except Exception as e:
                    print(f"    [Ошибка в процессе]: {e}")
                
                # Рандомная пауза, чтобы не забанили (от 15 до 25 секунд)
                await asyncio.sleep(20)

        if changed:
            try:
                df.to_excel(EXCEL_FILE, index=False)
                print("\n--- ТАБЛИЦА ОБНОВЛЕНА И СОХРАНЕНА ---")
            except Exception as e:
                print(f"Ошибка сохранения (закрой Excel!): {e}")

        print("Завершение работы...")
        await context.close()

if __name__ == "__main__":
    asyncio.run(run_agent())
